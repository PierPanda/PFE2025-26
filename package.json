{
  "name": "maestroo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "node --env-file=.env ./node_modules/@react-router/serve/dist/cli.js ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "format": "oxfmt .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx drizzle/seed.ts",
    "db:reset": "tsx drizzle/seed.ts --reset"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "dependencies": {
    "@heroui/react": "^2.8.10",
    "@iconify/react": "^6.0.2",
    "@internationalized/date": "3.10.1",
    "@neondatabase/serverless": "^1.0.2",
    "@react-router/node": "^7.13.2",
    "@react-router/serve": "^7.13.2",
    "@tanstack/react-query": "^5.95.2",
    "@vercel/react-router": "^1.2.6",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.6",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.38.0",
    "isbot": "^5.1.36",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.2",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "@internationalized/date": "3.10.1"
    },
    "onlyBuiltDependencies": [
      "@heroui/shared-utils",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@react-router/dev": "^7.13.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.57.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
